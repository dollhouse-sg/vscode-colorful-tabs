{
  "name": "colorful-tabs",
  "displayName": "Colorful Tabs",
  "description": "Tag files with a coloured marker visible on the editor tab and in the Explorer.",
  "version": "0.1.1",
  "publisher": "dollhouse-sg",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dollhouse-sg/vscode-colorful-tabs"
  },
  "bugs": {
    "url": "https://github.com/dollhouse-sg/vscode-colorful-tabs/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "file",
    "tabs",
    "color"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "colorTabs.setMarker",
        "title": "Set Marker",
        "category": "Colorful Tabs"
      }
    ],
    "menus": {
      "editor/title/context": [
        {
          "command": "colorTabs.setMarker",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "colorTabs.setMarker",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
